# .zshrc - Interactive shell configuration

# Path configuration
typeset -U path PATH
path=(
  $HOME/.local/bin
  $HOME/bin
  $HOME/.bin
  $CARGO_HOME/bin
  $GOBIN
  $N_PREFIX/bin
  $PNPM_HOME
  $HOME/.yarn/bin
  $HOME/.config/yarn/global/node_modules/.bin
  ./node_modules/.bin
  /opt/homebrew/bin
  /usr/local/bin
  $path
)

# CDPATH for quick directory navigation
CDPATH=.:$HOME:$HOME/dev:$HOME/Desktop

# Source Homebrew
[[ -f "/opt/homebrew/bin/brew" ]] && eval "$(/opt/homebrew/bin/brew shellenv)"

# Zinit plugin manager
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  print -P "%F{33}▓▒░ %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})…%f"
  command mkdir -p "$(dirname $ZINIT_HOME)"
  command git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME" && \
    print -P "%F{33}▓▒░ %F{34}Installation successful.%f%b" || \
    print -P "%F{160}▓▒░ The clone has failed.%f%b"
fi
source "${ZINIT_HOME}/zinit.zsh"

# Load plugins
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

# Oh My Zsh plugins
zinit snippet OMZP::git
zinit snippet OMZP::sudo
zinit snippet OMZP::command-not-found

# Load completions
autoload -Uz compinit && compinit
zinit cdreplay -q

# Zsh options
setopt EXTENDED_HISTORY
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_SAVE_NO_DUPS
setopt HIST_VERIFY
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt CORRECT
setopt CDABLE_VARS
setopt EXTENDED_GLOB
setopt NO_BEEP
setopt PROMPT_SUBST

# History configuration
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=${ZDOTDIR:-$HOME}/.zsh_history

# Completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always $realpath'

# Load additional configurations
[[ -f "$HOME/.config/zsh/aliases.zsh" ]] && source "$HOME/.config/zsh/aliases.zsh"
[[ -f "$HOME/.config/zsh/functions.zsh" ]] && source "$HOME/.config/zsh/functions.zsh"

# Node (nvm)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Deno
[[ -f "$HOME/.deno/env" ]] && . "$HOME/.deno/env"

# Rancher/k8s helper
rcs () {
    if ! ps | grep -q '[l]ocalhost:4443'; then
        gcloud auth print-access-token > /dev/null 2>&1 || gcloud auth login
        pkill -f ':4443'
        gcloud compute start-iap-tunnel acp-rancher-development 443 --local-host-port=localhost:4443 --zone=us-west2-a --project=acp-rancher-development-67 &> /dev/null &
        sleep 3
    fi
    rancher context switch
    sed -i '' 's|https://172.23.64.22:443|https://localhost:4443|g' /Users/axelm/.rancher/cli2.json
    PROJECT_ID=
    rancher clusters kubeconfig  > /Users/axelm/.kube/rancher.yaml
    sed -i '' 's|https://172.23.64.22:443|https://localhost:4443|g' /Users/axelm/.kube/rancher.yaml
    export KUBECONFIG=/Users/axelm/.kube/rancher.yaml
}

# Tool integrations
. "$HOME/.atuin/bin/env"
eval "$(atuin init zsh)"
eval "$(zoxide init --cmd cd zsh)"
source <(fzf --zsh)
eval "$(direnv hook zsh)"
eval "$(starship init zsh)"

# Key bindings
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region

# FZF configuration (catppuccin latte)
export FZF_DEFAULT_OPTS="
  --height 40% --layout=reverse --border
  --color=bg+:#ccd0da,bg:#eff1f5,spinner:#dc8a78,hl:#d20f39
  --color=fg:#4c4f69,header:#d20f39,info:#8839ef,pointer:#dc8a78
  --color=marker:#dc8a78,fg+:#4c4f69,prompt:#8839ef,hl+:#d20f39
"

# Terminal configuration
export CLICOLOR=1
export LSCOLORS=Fafacxdxbxegedabagacad

# Load local configuration if exists
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
