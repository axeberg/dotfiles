# Ghostty Configuration

# Font
font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true

# Theme
theme = Catppuccin Latte

# Cursor
cursor-style = block
cursor-blink = true

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true

# Scrolling
scrollback-limit = 10000

# Bell
audible-bell = false
visual-bell = true

# Mouse
mouse-hide-while-typing = true

# Copy on select
copy-on-select = true

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = cmd+k=clear
keybind = cmd+n=new_window
keybind = cmd+t=new_tab
keybind = cmd+w=close_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9

# macOS specific
macos-option-as-alt = true
macos-titlebar-style = tabs
